{
  "ReverseProxy": {
    "Routes": {
      "authRoute": {
        "ClusterId": "authCluster",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "expenseRoute": {
        "ClusterId": "expenseCluster",
        "Match": {
          "Path": "/expenses/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "authCluster": {
        "Destinations": {
          "authService": {
            "Address": "http://authservice/"
          }
        }
      },
      "expenseCluster": {
        "Destinations": {
          "expenseService": {
            "Address": "http://expenseservice/"
          }
        }
      }
    }
  }
}